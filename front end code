<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Construction AI Planner</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #eef2f5;
            margin: 0;
            padding: 0;
        }

        .container {
            width: 55%;
            margin: 40px auto;
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 0 15px rgba(0,0,0,0.12);
        }

        h1 {
            text-align: center;
            color: #223b57;
            margin-bottom: 30px;
        }

        label {
            font-weight: bold;
            display: block;
            margin-top: 15px;
            margin-bottom: 8px;
        }

        input, button {
            width: 100%;
            padding: 12px;
            border: 1px solid #cfcfcf;
            border-radius: 6px;
            box-sizing: border-box;
            font-size: 15px;
        }

        button {
            margin-top: 22px;
            background: #2f4358;
            color: white;
            border: none;
            cursor: pointer;
        }

        button:hover {
            background: #1f3144;
        }

        .result {
            margin-top: 25px;
            padding: 20px;
            background: #eaf3ff;
            border-left: 5px solid #3498db;
            white-space: pre-line;
            font-size: 16px;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Construction AI Planner</h1>

        <form method="POST">
            <label>Project Type</label>
            <input type="text" name="project" placeholder="Enter project type" required>

            <label>Area (sq ft)</label>
            <input type="number" name="area" placeholder="Enter area" required>

            <label>Budget</label>
            <input type="number" name="budget" placeholder="Enter budget in rupees" required>

            <label>Location</label>
            <input type="text" name="location" placeholder="Enter location" required>

            <label>Number of Floors</label>
            <input type="number" name="floors" placeholder="Enter number of floors" required>

            <button type="submit">Generate Plan</button>
        </form>

        {% if result %}
        <div class="result">
            {{ result }}
        </div>
        {% endif %}
    </div>
</body>
</html>